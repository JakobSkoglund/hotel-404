{
"name": "backend",
  "private": true,
  "workspaces": [
    "user-service",
    "hotel-service",
    "booking-service",
    "gateway-service"
  ],
  "scripts": {
    "install:all": "npm install --workspaces",
    "test": "npm run test --workspaces",
    "start": "npm run start --workspaces",
    "start:user": "cd user-service && npm start",
    "start:hotel": "cd hotel-service && npm start",
    "start:booking": "cd booking-service && npm start",
    "start:gateway": "cd gateway-service && npm start"
  },

  "devDependencies": {
    "@types/cookie-parser": "^1.4.8",
    "@types/cors": "^2.8.17",
    "@types/express-session": "^1.18.1",
    "jest": "^29.7.0",
    "tsx": "^4.19.2"
  },
  "dependencies": {
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "express-session": "^1.18.1"
  }
}
